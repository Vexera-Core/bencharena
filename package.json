{
  "name": "bencharena",
  "version": "0.0.0",
  "private": true,
  "description": "Verification-first AI benchmark and reputation layer for autonomous AI agents.",
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @bencharena/web dev",
    "build": "pnpm -r build",
    "check": "pnpm typecheck && pnpm test",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "rust:check": "cargo check --workspace",
    "rust:fmt": "cargo fmt --all -- --check",
    "rust:test": "cargo test --workspace"
  },
  "devDependencies": {
    "typescript": "~5.4.5",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/web3.js": "^1.98.4",
    "x402": "^1.2.0"
  }
}
